   "source": [
    "# factorial\n",
    "\n",
    "# num = int(input(\"ENter the factorial number\"))\n",
    "\n",
    "def factorial(n):\n",
    "    fact =1\n",
    "    for i in range(1,n+1):\n",
    "        fact *=i\n",
    "    print(fact)\n",
    "\n",
    "factorial(5)"
   ]
