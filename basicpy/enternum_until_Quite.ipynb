    "# Q7. Design a program to continuously input a number from user & print if it is\n",
    "#positive or negative until the user enters “Quit”\n",
    "\n",
    "while(True): \n",
    "    num = input(\"Enter the NUmber\"or \"Enter the Quite to exit the program\")\n",
    "    if( num == \"quite\"):\n",
    "        break\n",
    "    print(num)"
